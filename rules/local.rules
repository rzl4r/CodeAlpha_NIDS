# Detect port scan
alert tcp any any -> $HOME_NET any (msg:"Port Scan Detected"; flags:S; threshold:type both,track by_src,count 20,seconds 2; sid:9000001; rev:1;)

# Detect SSH brute force
alert tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force Attempt"; threshold:type both,track by_src,count 5,seconds 30; sid:9000002; rev:1;)

# Detect SQL injection
alert http any any -> $HOME_NET any (msg:"SQL Injection Attempt"; content:"' OR 1=1"; http_uri; sid:9000003; rev:1;)

# Detect ICMP flood
alert icmp any any -> $HOME_NET any (msg:"ICMP Flood DoS"; threshold:type both,track by_src,count 100,seconds 1; sid:9000004; rev:1;)
